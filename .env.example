APP_NAME=vps-nat
APP_ENV=development

HTTP_HOST=0.0.0.0
HTTP_PORT=8080

AUTH_ADMIN_SESSION_TTL=24h

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=vps_nat
DB_SSLMODE=disable
DB_TIMEZONE=UTC
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=5m

INCUS_ENABLED=false
INCUS_MODE=unix
INCUS_SOCKET=/var/lib/incus/unix.socket
INCUS_REMOTE_ADDR=https://127.0.0.1:8443
INCUS_USER_AGENT=vps-nat-backend
INCUS_TLS_CLIENT_CERT_PATH=
INCUS_TLS_CLIENT_KEY_PATH=
INCUS_TLS_CA_PATH=
INCUS_TLS_SERVER_CERT_PATH=
INCUS_TLS_INSECURE_SKIP_VERIFY=false
